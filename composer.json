{
    "name": "nimblephp/settings",
    "description": "Runtime key-value settings for NimblePHP, stored in the database with typed values and per-request caching",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "NimblePHP\\Settings\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "NimblePHP\\Settings\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Krzysztof Żyłka",
            "email": "krzysztofzylka@yahoo.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "nimblephp/framework": ">=0.4.14",
        "nimblephp/migrations": ">=0.3.2",
        "krzysztofzylka/database-manager": ">=1.1.22"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "scripts": {
        "test": "phpunit"
    }
}
